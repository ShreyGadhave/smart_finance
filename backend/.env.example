# External APIs
GNEWS_API_KEY=
ALPHA_VANTAGE_KEY=
GROQ_API_KEY=

# Supabase (backend only)
# Use your project URL, e.g. https://xyzcompany.supabase.co
SUPABASE_URL=
# Use SERVICE_ROLE key here (Settings -> API -> service_role). Never expose this in frontend.
SUPABASE_KEY=
# Optional fallback user id for script runs (Supabase Auth user UUID).
DEFAULT_USER_ID=

# Storage tables
SUPABASE_TABLE=pipeline_runs
SUPABASE_ARTICLES_TABLE=pipeline_articles
